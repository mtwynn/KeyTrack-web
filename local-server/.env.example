# Copy this file to `.env` and fill in your app credentials.
# The backend loads `.env` automatically (via dotenv) on every start, so you
# only set these once for local development.
#
# --- Spotify ---
# Get these from your Spotify app at https://developer.spotify.com/dashboard
# and make sure http://127.0.0.1:8888/callback is added as a Redirect URI.
SPOTIFY_ID=your_spotify_client_id
SPOTIFY_SECRET=your_spotify_client_secret

# --- SoundCloud ---
# Register an app at https://soundcloud.com/you/apps/new (requires Artist Pro).
# Add this exact Redirect URI for local dev:
#   http://127.0.0.1:8888/soundcloud/callback
# (When deploying, change the registered URI to:
#   https://key-track2.herokuapp.com/soundcloud/callback )
SOUNDCLOUD_ID=your_soundcloud_client_id
SOUNDCLOUD_SECRET=your_soundcloud_client_secret
